# Database
DATABASE_URL="postgresql://user:password@localhost:5432/bgroup_super_app"

# NextAuth (v4 legacy aliases)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here"

# NextAuth v5 / Auth.js — required for `next start` (production mode). Without
# all three, every /api/auth/* request 500s with UntrustedHost. Browser shows
# "Invalid email or password" because the credential check is never reached.
# In real production, set AUTH_URL to the deployed origin and drop
# AUTH_TRUST_HOST.
AUTH_URL="http://localhost:3000"
AUTH_SECRET="your-secret-key-here"
AUTH_TRUST_HOST="true"

# Google OAuth (CRM)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (Magic Link - CRM)
RESEND_API_KEY=""
EMAIL_FROM="BGroup <noreply@bgroup.com>"

# HR Module (JWT for legacy HR auth)
JWT_SECRET="your-hr-jwt-secret-here"

# SMTP (Partners email notifications)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@bgroup.com"
